# Test overrides for the Expo app environment variables.
# Used by Docker/CI builds that target the isolated test stack.
EXPO_PUBLIC_API_URL='http://localhost:8000'     # The URL of the test backend API.
EXPO_PUBLIC_WEBSITE_URL='http://localhost:8010' # The URL of the test frontend website.
EXPO_PUBLIC_DOCS_URL='http://localhost:8012'    # The URL of the test documentation site.
