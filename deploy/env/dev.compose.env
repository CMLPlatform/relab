# deploy/env/dev.compose.env - committed, non-secret Compose interpolation vars for local dev.
# Loaded by root just recipes for the Docker full-stack development workflow.

ENVIRONMENT=dev
API_PUBLIC_URL=http://localhost:8011
APP_PUBLIC_URL=http://localhost:8013
OAUTH_ALLOWED_REDIRECT_URIS=["http://localhost:8013/login","http://localhost:8013/profile","relab-app://login","relab-app://profile"]
WEB_PUBLIC_URL=http://localhost:8010
DOCS_PUBLIC_URL=http://localhost:8012
