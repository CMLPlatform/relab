# deploy/env/prod.compose.env - committed, non-secret Compose interpolation vars for prod.
# Loaded by the root deploy recipes. Host-local operator inputs live in the
# gitignored root `.env` on each deploy host; runtime secrets live in secrets/prod/.

ENVIRONMENT=prod
API_PUBLIC_URL=https://api.cml-relab.org
APP_PUBLIC_URL=https://app.cml-relab.org
OAUTH_ALLOWED_REDIRECT_URIS=["https://app.cml-relab.org/login","https://app.cml-relab.org/profile","relab-app://login","relab-app://profile"]
SITE_PUBLIC_URL=https://cml-relab.org
DOCS_PUBLIC_URL=https://docs.cml-relab.org

WEB_CONCURRENCY=4
