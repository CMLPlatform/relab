# deploy/env/prod.compose.env — committed, non-secret Compose interpolation vars for prod.
# Loaded by the root justfile deploy recipes. Secrets and host-local overrides
# live in the gitignored root `.env` on each deploy host.

APP_ENV=prod
COMPOSE_PROJECT_NAME=relab_prod
WEB_CONCURRENCY=4
BUILD_MODE=prod
PUBLIC_SITE_URL=https://docs.cml-relab.org
CSP_API_ORIGIN=https://api.cml-relab.org
