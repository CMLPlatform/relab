# deploy/env/staging.compose.env - committed, non-secret Compose interpolation vars for staging.
# Loaded by the root deploy recipes. Host-local operator inputs live in the
# gitignored root `.env` on each deploy host; runtime secrets live in secrets/staging/.

ENVIRONMENT=staging
API_PUBLIC_URL=https://api-test.cml-relab.org
APP_PUBLIC_URL=https://app-test.cml-relab.org
OAUTH_ALLOWED_REDIRECT_URIS=["https://app-test.cml-relab.org/login","https://app-test.cml-relab.org/profile","relab-app://login","relab-app://profile"]
WEB_PUBLIC_URL=https://web-test.cml-relab.org
DOCS_PUBLIC_URL=https://docs-test.cml-relab.org

WEB_CONCURRENCY=2
