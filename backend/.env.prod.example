# Production backend runtime variables.
# Copy this file to .env.prod and fill in the non-secret values marked with 🔀.
# This file is loaded automatically when ENVIRONMENT=prod.

# Database settings
DATABASE_HOST='localhost'          # Overridden by Compose in Docker
DATABASE_SSL='false'              # Disable TLS for the internal Docker Postgres service
POSTGRES_USER='postgres'          # Bootstrap/admin role used only by the Postgres container
POSTGRES_DB='relab_db'            # 🔀
DATABASE_APP_USER='relab_app'
DATABASE_MIGRATION_USER='relab_migrator'
DATABASE_BACKUP_USER='relab_backup'
# Database, Redis, and backup passwords live in root secrets/prod/* files mounted by Compose.
# Required filenames are tracked in deploy/required-secret-files.txt.

# Application secrets
# Keep application secrets in the deploy host's backend/.env.prod for now:
# FASTAPI_USERS_SECRET, DATA_ENCRYPTION_KEYS, OAuth client secrets, email provider
# secrets, and SUPERUSER_PASSWORD. Compose secret files are reserved for
# Postgres, Redis, and restic credentials.

# OAuth settings
GOOGLE_OAUTH_CLIENT_ID=''        # 🔀
GITHUB_OAUTH_CLIENT_ID=''        # 🔀

# Email delivery. Use smtp for Google Workspace or any SMTP relay; use microsoft_graph for Microsoft 365.
EMAIL_PROVIDER='smtp'
EMAIL_HOST=''                    # 🔀
EMAIL_USERNAME=''                # 🔀
EMAIL_FROM=''                    # 🔀
EMAIL_REPLY_TO=''                # 🔀
MICROSOFT_GRAPH_TENANT_ID=''     # Required when EMAIL_PROVIDER='microsoft_graph'
MICROSOFT_GRAPH_CLIENT_ID=''     # Required when EMAIL_PROVIDER='microsoft_graph'
MICROSOFT_GRAPH_SENDER_USER=''   # Mailbox/user principal name to send from
MICROSOFT_GRAPH_SAVE_TO_SENT_ITEMS='false'

# Redis settings
REDIS_HOST='localhost'           # Overridden by Compose in Docker
# REDIS_PASSWORD lives in secrets/prod/redis_password for deploy Compose.

# Superuser details (only used on first deploy to create the account)
SUPERUSER_EMAIL=''               # 🔀
SUPERUSER_NAME=''                # Optional. Can only contain lowercase letters, numbers, and underscores.

# Network settings
BACKEND_API_URL='https://api.cml-relab.org'
FRONTEND_APP_URL='https://app.cml-relab.org'
FRONTEND_WEB_URL='https://cml-relab.org'

# Observability (OpenTelemetry tracing) — OFF by default.
# Set OTEL_EXPORTER_OTLP_ENDPOINT in the host's root .env to enable.
# Empty/unset endpoint = OTEL disabled.

# Resource tuning
# Most request/upload/rate/frame limits are source defaults; tune only host-sized capacity here.
UVICORN_LIMIT_CONCURRENCY='100'
