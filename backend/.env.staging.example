# Staging environment variables.
# Copy this file to .env.staging and fill in the values marked with 🔀.
# This file is loaded automatically when ENVIRONMENT=staging.

# Database settings
DATABASE_HOST='localhost'          # Overridden by Compose in Docker
DATABASE_SSL='false'              # Disable TLS for the internal Docker Postgres service
POSTGRES_USER='postgres'          # 🔀
POSTGRES_PASSWORD=''              # 🔀 Use a strong generated password
POSTGRES_DB='relab_db'            # 🔀

## Authentication settings
FASTAPI_USERS_SECRET=''  # 🔀 Generate: uv run python -c "import secrets; print(secrets.token_urlsafe(32))"
DATA_ENCRYPTION_KEYS=''  # 🔀 Comma-separated Fernet keyring. Generate: uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# OAuth settings
GOOGLE_OAUTH_CLIENT_ID=''        # 🔀
GOOGLE_OAUTH_CLIENT_SECRET=''    # 🔀
GITHUB_OAUTH_CLIENT_ID=''        # 🔀
GITHUB_OAUTH_CLIENT_SECRET=''    # 🔀

# Email delivery. Use smtp for Google Workspace or any SMTP relay; use microsoft_graph for Microsoft 365.
EMAIL_PROVIDER='smtp'
EMAIL_HOST=''                    # 🔀
EMAIL_USERNAME=''                # 🔀
EMAIL_PASSWORD=''                # 🔀
EMAIL_FROM=''                    # 🔀
EMAIL_REPLY_TO=''                # 🔀
MICROSOFT_GRAPH_TENANT_ID=''     # Required when EMAIL_PROVIDER='microsoft_graph'
MICROSOFT_GRAPH_CLIENT_ID=''     # Required when EMAIL_PROVIDER='microsoft_graph'
MICROSOFT_GRAPH_CLIENT_SECRET='' # Required when EMAIL_PROVIDER='microsoft_graph'
MICROSOFT_GRAPH_SENDER_USER=''   # Mailbox/user principal name to send from
MICROSOFT_GRAPH_SAVE_TO_SENT_ITEMS='false'

# Redis settings
REDIS_HOST='localhost'           # Overridden by Compose in Docker
REDIS_PASSWORD=''                # 🔀

# Superuser details
SUPERUSER_EMAIL=''               # 🔀
SUPERUSER_PASSWORD=''            # 🔀
SUPERUSER_NAME=''                # Optional. Can only contain lowercase letters, numbers, and underscores.

# Network settings
BACKEND_API_URL='https://api-test.cml-relab.org'
FRONTEND_APP_URL='https://app-test.cml-relab.org'
FRONTEND_WEB_URL='https://web-test.cml-relab.org'

# Observability (OpenTelemetry tracing) — OFF by default.
# Set OTEL_EXPORTER_OTLP_ENDPOINT in the host's root .env to enable.
# Empty/unset endpoint = OTEL disabled.

# Resource tuning
# Most request/upload/rate/frame limits are source defaults; tune only host-sized capacity here.
UVICORN_LIMIT_CONCURRENCY='100'
