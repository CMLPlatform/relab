# Backend-only development environment variables.
# Copy this file to .env.dev for standalone backend dev and fill values marked with 🔀.
# This file is loaded automatically when ENVIRONMENT=dev (the default).
#
# Production and staging do not use backend dotenv files. Deployment config is:
# - committed non-secret environment identity in root deploy/env/*.compose.env
# - host-local operator inputs in root .env
# - runtime secrets in root secrets/<env>/

# Database settings
DATABASE_HOST='127.0.0.1'         # Overridden by Compose in Docker
DATABASE_SSL='false'              # Disable TLS for the internal Docker Postgres service
POSTGRES_USER='postgres'          # 🔀 Username that has access to the database
POSTGRES_DB='relab_db'            # 🔀 Name of the database
DATABASE_APP_USER='relab_app'
DATABASE_MIGRATION_USER='relab_migrator'
DATABASE_BACKUP_USER='relab_backup'
# Runtime secrets live in root secrets/dev/* files mounted by Compose.
# Create any missing files with: (cd .. && just deploy-secrets-template dev)

## Authentication settings
# Store application secrets in secrets/dev/*, not in this non-secret env file.
# Create missing local development secrets with:
# (cd .. && just deploy-secrets-template dev)

# OAuth settings
GOOGLE_OAUTH_CLIENT_ID='google-oauth-client-id'             # 🔀 Client ID for Google OAuth
GITHUB_OAUTH_CLIENT_ID='github-oauth-client-id'             # 🔀 Client ID for GitHub OAuth

# Email delivery. Use smtp for Google Workspace or any SMTP relay; use microsoft_graph for Microsoft 365.
EMAIL_PROVIDER='smtp'
EMAIL_HOST='smtp.example.com'                               # 🔀
EMAIL_USERNAME='your.email@example.com'                     # 🔀 Username for the SMTP server
EMAIL_FROM='Your Name <your.sending.alias.@example.com>'    # Optional. Defaults to EMAIL_USERNAME when omitted.
EMAIL_REPLY_TO='your.replyto.alias.@example.com'            # Optional. Defaults to EMAIL_USERNAME when omitted.
MICROSOFT_GRAPH_TENANT_ID=''                                # Required when EMAIL_PROVIDER='microsoft_graph'
MICROSOFT_GRAPH_CLIENT_ID=''                                # Required when EMAIL_PROVIDER='microsoft_graph'
MICROSOFT_GRAPH_SENDER_USER=''                              # Mailbox/user principal name to send from
MICROSOFT_GRAPH_SAVE_TO_SENT_ITEMS='false'

# Redis settings for caching (disposable email domains, sessions, etc.)
REDIS_HOST='127.0.0.1'                                      # Overridden by Compose in Docker

# Superuser details
SUPERUSER_EMAIL='your-email@example.com' # 🔀
SUPERUSER_NAME='your_name'               # Optional. Can only contain lowercase letters, numbers, and underscores.

# Network settings (overridden by compose.dev.yml in Docker)
BACKEND_API_URL='http://127.0.0.1:8001'
FRONTEND_APP_URL='http://127.0.0.1:8003'
FRONTEND_WEB_URL='http://127.0.0.1:8000'

# Allow CORS from any LAN IP (dev only; blocked in production).
# Default covers localhost, 127.0.0.1, and the 192.168.x.x subnet.
# If your local network uses a different range (e.g. 10.0.x.x), update this regex.
CORS_ORIGIN_REGEX=r'https?://(localhost|127\.0\.0\.1|192\.168\.\d+\.\d+)(:\d+)?'

# Optional OpenTelemetry tracing
