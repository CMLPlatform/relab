# Staging environment variables for the web frontend.
# Loaded automatically when building with: astro build --mode staging
# (i.e. npm run build:staging / just build-staging)
PUBLIC_API_URL='https://api-test.cml-relab.org'    # The URL of the staging backend API.
PUBLIC_DOCS_URL='https://docs.cml-relab.org' # The URL of the docs website (doesn't have staging version yet)
PUBLIC_APP_URL='https://app-test.cml-relab.org'    # The URL of the staging application frontend.

PUBLIC_LINKEDIN_URL='https://www.linkedin.com/groups/15671021' # The URL of the LinkedIn page.
PUBLIC_CONTACT_EMAIL='relab@cml.leidenuniv.nl' # The email address for contact inquiries.
