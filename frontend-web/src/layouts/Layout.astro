---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Reverse Engineering Lab — bottom-up product data collection for circular economy research.',
} = Astro.props;
const linkedInUrl = import.meta.env.PUBLIC_LINKEDIN_URL;
const contactEmail = import.meta.env.PUBLIC_CONTACT_EMAIL ?? 'relab@cml.leidenuniv.nl';
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="nav-shell">
        <a href="/" aria-label="Home" class="brand-link">
          <img src="/favicon.png" alt="ReLab logo" width="28" height="28" />
          <span>ReLab</span>
        </a>
      </div>
    </header>

    <main class="page-shell">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-left">
        <a href="/privacy" class="footer-text-link">Privacy Policy</a>
        <span class="footer-copy" aria-label={`Copyright ${currentYear} CML, Leiden University`}>© {currentYear} CML, Leiden University</span>
      </div>

      <div class="footer-social">
        <a
          href="https://github.com/CMLPlatform/relab"
          class="footer-icon-link"
          aria-label="GitHub"
          title="GitHub"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2C6.475 2 2 6.475 2 12a10 10 0 0 0 6.838 9.488c.5.087.687-.213.687-.476 0-.237-.013-.875-.013-1.725-2.512.463-3.162-.612-3.362-1.175-.113-.288-.6-1.175-1.025-1.413-.35-.187-.85-.65-.013-.662.788-.013 1.35.725 1.538 1.025.9 1.512 2.338 1.087 2.912.825.088-.65.35-1.087.638-1.337-2.225-.25-4.55-1.113-4.55-4.938 0-1.088.387-1.987 1.025-2.688-.1-.25-.45-1.275.1-2.65 0 0 .837-.262 2.75 1.026a9.28 9.28 0 0 1 2.5-.338c.85 0 1.7.112 2.5.337 1.912-1.3 2.75-1.024 2.75-1.024.55 1.375.2 2.4.1 2.65.637.7 1.025 1.587 1.025 2.687 0 3.838-2.337 4.688-4.562 4.938.362.312.675.912.675 1.85 0 1.337-.013 2.412-.013 2.75 0 .262.188.574.688.474A10.016 10.016 0 0 0 22 12c0-5.525-4.475-10-10-10z"/>
          </svg>
        </a>

        {
          linkedInUrl && (
            <a
              href={linkedInUrl}
              class="footer-icon-link"
              aria-label="LinkedIn Group"
              title="LinkedIn Group"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          )
        }

        <a
          href={`mailto:${contactEmail}`}
          class="footer-icon-link"
          aria-label={`Email ${contactEmail}`}
          title={contactEmail}
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/>
          </svg>
        </a>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 30;
    backdrop-filter: blur(8px);
    background: color-mix(in srgb, var(--color-surface) 82%, transparent);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-shell {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0.85rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--color-on-surface);
    font-weight: 600;
    font-size: 1.1rem;
  }

  .brand-link img {
    border-radius: 7px;
  }

  .page-shell {
    flex: 1;
    max-width: 1080px;
    width: 100%;
    margin: 0 auto;
    padding: 2.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* Sticky footer — mirrors the header pattern (no z-index: backdrop-filter handles compositing) */
  .site-footer {
    position: sticky;
    bottom: 0;
    backdrop-filter: blur(8px);
    background: color-mix(in srgb, var(--color-surface) 88%, transparent);
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.6rem 1.5rem;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  .footer-text-link {
    font-size: 0.8rem;
    color: var(--color-muted);
    text-decoration: none;
    white-space: nowrap;
  }

  .footer-text-link:hover {
    color: var(--color-on-surface);
    text-decoration: underline;
  }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--color-muted);
    opacity: 0.7;
    white-space: nowrap;
  }

  .footer-social {
    display: flex;
    align-items: center;
    gap: 0.15rem;
  }

  .footer-icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    color: var(--color-muted);
    text-decoration: none;
    transition:
      color 160ms ease,
      background 160ms ease;
  }

  .footer-icon-link:hover {
    color: var(--color-on-surface);
    background: color-mix(in srgb, var(--color-on-surface) 8%, transparent);
  }

  .footer-icon-link svg {
    width: 17px;
    height: 17px;
    fill: currentColor;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .nav-shell {
      padding: 0.8rem 1rem;
    }

    .page-shell {
      padding: 1.8rem 1rem;
    }

    .site-footer {
      padding: 0.6rem 1rem;
    }

    .footer-copy {
      font-size: 0.75rem;
    }
  }
</style>
