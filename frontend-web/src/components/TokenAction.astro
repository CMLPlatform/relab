---
interface Props {
  title: string;
  apiUrl: string;
  loadingMessage: string;
  successMessage: string;
  noTokenMessage: string;
  defaultErrorMessage: string;
}

const { title, apiUrl, loadingMessage, successMessage, noTokenMessage, defaultErrorMessage } =
  Astro.props;
---

<token-action
  class="card stack-md"
  data-api-url={apiUrl}
  data-success-message={successMessage}
  data-no-token-message={noTokenMessage}
  data-default-error-message={defaultErrorMessage}
>
  <h1>{title}</h1>
  <div id="status" class="status status-loading" role="status" aria-live="polite">
    <div class="spinner" aria-hidden="true"></div>
    <p>{loadingMessage}</p>
  </div>
</token-action>

<script>
  class TokenAction extends HTMLElement {
    connectedCallback() {
      if (this.dataset.initialized === 'true') {
        return;
      }

      this.dataset.initialized = 'true';

      const statusEl = this.querySelector<HTMLElement>('#status');
      if (!statusEl) {
        return;
      }

      const show = (message: string, state: 'success' | 'error') => {
        const text = document.createElement('p');
        text.textContent = message;
        statusEl.className = `status status-${state}`;
        statusEl.replaceChildren(text);
      };

      const token = new URLSearchParams(window.location.search).get('token');
      if (!token) {
        show(this.dataset.noTokenMessage ?? 'No token provided.', 'error');
        return;
      }

      fetch(this.dataset.apiUrl ?? '', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(token),
      })
        .then(async (response) => {
          if (response.ok) {
            show(this.dataset.successMessage ?? 'Success!', 'success');
            window.setTimeout(() => {
              window.location.href = '/';
            }, 3000);
            return;
          }

          const payload = (await response.json().catch(() => null)) as { detail?: string } | null;
          show(payload?.detail ?? this.dataset.defaultErrorMessage ?? 'Request failed.', 'error');
        })
        .catch(() => {
          show('An error occurred. Please try again later.', 'error');
        });
    }
  }

  customElements.define('token-action', TokenAction);
</script>
