---
interface LinkItem {
  href: string;
  label: string;
}

interface Props {
  links: LinkItem[];
}

const { links } = Astro.props;
---

<div class="support-links">
  <p class="support-links-label">Need more context?</p>
  <ul class="primary-links" aria-label="Supporting links">
  {
    links.map((link) => (
      <li>
        <a href={link.href} class="primary-link" target="_blank" rel="noopener noreferrer">
          {link.label}
        </a>
      </li>
    ))
  }
  </ul>
</div>
