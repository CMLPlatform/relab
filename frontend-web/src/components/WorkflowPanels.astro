---
import { homeContent } from '@/content/home-content.ts';
---

<section class="workflow-shell card content-section content-reveal">
  <div class="section-copy">
    <p class="section-kicker">Workflow overview</p>
    <h2>{homeContent.workflowTitle}</h2>
    <p>{homeContent.workflowIntro}</p>
  </div>

  <div class="workflow-grid" aria-label="RELab workflow">
    {
      homeContent.workflowSteps.map((step) => (
        <article class="workflow-card">
          <p class="workflow-label">{step.label}</p>
          <h3>{step.title}</h3>
          <p>{step.body}</p>
        </article>
      ))
    }
  </div>
</section>
