---
import { homeContent } from '@/content/home-content.ts';
import PrimaryLinks from './PrimaryLinks.astro';

interface Props {
  githubUrl: string;
  linkedInUrl?: string;
}

const { githubUrl, linkedInUrl } = Astro.props;

const links = [{ href: githubUrl, label: 'Browse GitHub' }];
if (linkedInUrl) {
  links.push({ href: linkedInUrl, label: 'Follow LinkedIn' });
}
---

<section class="newsletter-shell card content-section content-reveal">
  <div class="newsletter-copy follow-shell">
    <p class="section-kicker">Public channels</p>
    <h2>{homeContent.updatesTitle}</h2>
    <p>{homeContent.updatesBody}</p>
    <PrimaryLinks label={homeContent.updatesFollowLabel} links={links} />
  </div>
</section>
