---
import { homeContent } from '@/content/home-content.ts';
import PrimaryLinks from './PrimaryLinks.astro';

interface Props {
  docsUrl: string;
  githubUrl: string;
}

const { docsUrl, githubUrl } = Astro.props;
---

<section class="trust-shell card content-section content-reveal">
  <div class="section-copy trust-copy">
    <p class="section-kicker">Research context</p>
    <h2>{homeContent.trustTitle}</h2>
    <p>{homeContent.trustBody}</p>
  </div>

  <div class="trust-details">
    <ul class="fact-list">
      {homeContent.trustFacts.map((fact) => <li>{fact}</li>)}
    </ul>

    <PrimaryLinks
      label={homeContent.trustLinksLabel}
      links={[
        { href: docsUrl, label: homeContent.primaryCtas.docs },
        { href: githubUrl, label: homeContent.primaryCtas.github },
      ]}
    />
  </div>
</section>
