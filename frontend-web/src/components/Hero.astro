---

import { siteMeta } from '@/content/site-meta.ts';

interface Props {
  appUrl: string;
  docsUrl: string;
  githubUrl: string;
}

const { appUrl, docsUrl, githubUrl } = Astro.props;
const primaryCtas = {
  app: 'Open the app',
  docs: 'Read the docs',
  github: 'Browse source',
};
---

<section class="hero-panel card content-reveal">
  <div class="hero-copy">
    <h1>{siteMeta.title}</h1>
    <p class="hero-lead">{siteMeta.defaultDescription}</p>

    <div class="hero-actions">
      <a
        href={appUrl}
        class="btn btn-primary btn-large"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Open the RELab app"
      >
        {primaryCtas.app}
      </a>
      <a
        href={docsUrl}
        class="btn btn-muted btn-large"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Read the RELab documentation"
      >
        {primaryCtas.docs}
      </a>
      <a
        href={githubUrl}
        class="btn btn-muted btn-large"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Browse the RELab source code on GitHub"
      >
        {primaryCtas.github}
      </a>
    </div>
  </div>
</section>
