---
import { homeContent } from '@/content/home-content.ts';
import { newsletterContent } from '@/content/newsletter-content.ts';
import EmailForm from './EmailForm.astro';

interface Props {
  apiUrl: string;
}

const { apiUrl } = Astro.props;
---

<section class="newsletter-shell card content-section content-reveal">
  <div class="newsletter-copy">
    <h2>{homeContent.newsletterTitle}</h2>
    <p>{homeContent.newsletterBody}</p>
  </div>

  <div class="newsletter-form-shell">
    <EmailForm
      apiUrl={apiUrl}
      buttonText={newsletterContent.signup.buttonText}
      submittingText={newsletterContent.signup.submittingText}
      successMessage={newsletterContent.signup.successMessage}
    >
      <p class="muted-text">
        {newsletterContent.signup.consentText} <a href="/privacy">{newsletterContent.signup.consentLinkLabel}</a>.
      </p>
    </EmailForm>
  </div>
</section>
