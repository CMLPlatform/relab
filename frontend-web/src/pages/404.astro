---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Page not found" description="The page you requested could not be found." noIndex={true}>
  <section class="card empty-state content-reveal">
    <h1>Page not found</h1>
    <p>Try the homepage.</p>
    <div class="button-row">
      <a href="/" class="btn btn-primary">Back to homepage</a>
    </div>
  </section>
</Layout>
