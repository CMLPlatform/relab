---
import ContentPage from '@/components/ContentPage.astro';
import { privacyContent } from '@/content/privacy-content.ts';
import Layout from '@/layouts/Layout.astro';
---

<Layout title={privacyContent.title} description={privacyContent.description}>
  <ContentPage
    title={privacyContent.title}
    meta={privacyContent.lastUpdated}
    intro={privacyContent.intro}
  >
    <section class="stack-md content-section">
      {
        privacyContent.sections.map((section) => (
          <article class="card stack-sm">
            <h2>{section.title}</h2>
            {section.paragraphs?.map((paragraph) => <p>{paragraph}</p>)}
            {section.htmlParagraphs?.map((paragraph) => <p set:html={paragraph}></p>)}
          </article>
        ))
      }
    </section>
  </ContentPage>
</Layout>
