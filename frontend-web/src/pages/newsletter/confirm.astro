---
import TokenAction from '@/components/TokenAction.astro';
import { getPublicSiteConfig } from '@/config/public.ts';
import { newsletterContent } from '@/content/newsletter-content.ts';
import Layout from '@/layouts/Layout.astro';
import { joinApiUrl } from '@/utils/url.ts';

const newsletterConfirmUrl = joinApiUrl(getPublicSiteConfig().apiUrl, '/newsletter/confirm');
---

<Layout title={newsletterContent.confirmToken.documentTitle}>
  <TokenAction
    title={newsletterContent.confirmToken.title}
    apiUrl={newsletterConfirmUrl}
    loadingMessage={newsletterContent.confirmToken.loadingMessage}
    successMessage={newsletterContent.confirmToken.successMessage}
    noTokenMessage={newsletterContent.confirmToken.noTokenMessage}
    defaultErrorMessage={newsletterContent.confirmToken.defaultErrorMessage}
  />
</Layout>
