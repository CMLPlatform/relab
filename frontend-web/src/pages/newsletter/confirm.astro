---
import Layout from '@/layouts/Layout.astro';
import { joinApiUrl } from '@/utils/url';

const apiUrl = import.meta.env.PUBLIC_API_URL;
const newsletterConfirmUrl = joinApiUrl(apiUrl, '/newsletter/confirm');
---

<Layout title="Confirm Newsletter Subscription — RELab">
  <div class="card">
    <h1>Newsletter Subscription</h1>
    <div id="status" class="status status-loading">
      <div class="spinner" aria-hidden="true"></div>
      <p>Confirming your newsletter subscription…</p>
    </div>
  </div>
</Layout>

<script is:inline define:vars={{ newsletterConfirmUrl }}>
  const statusEl = document.getElementById('status');

  function show(message, state) {
    statusEl.className = 'status status-' + state;
    statusEl.innerHTML = `<p>${message}</p>`;
  }

  const params = new URLSearchParams(window.location.search);
  const token = params.get('token');

  if (!token) {
    show('No confirmation token provided. Please check your confirmation email.', 'error');
  } else {
    fetch(newsletterConfirmUrl, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(token),
    })
      .then(async (res) => {
        const data = await res.json();
        if (res.ok) {
          show('Newsletter subscription confirmed! Redirecting to the homepage…', 'success');
          setTimeout(() => (window.location.href = '/'), 3000);
        } else {
          show(data.detail || 'Confirmation failed. Please try registering again.', 'error');
        }
      })
      .catch(() => show('An error occurred. Please try again later.', 'error'));
  }
</script>

<style>
  h1 {
    font-size: 1.6rem;
    font-weight: 600;
    margin: 0 0 1.25rem;
  }

  .status {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .status p {
    margin: 0;
    line-height: 1.5;
  }

  .status-success p {
    color: #2e7d32;
  }
  .status-error p {
    color: #c62828;
  }
  .status-loading p {
    color: var(--color-muted);
  }

  .spinner {
    width: 28px;
    height: 28px;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    flex-shrink: 0;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>
