---
import TokenAction from '@/components/TokenAction.astro';
import { getPublicSiteConfig } from '@/config/public';
import Layout from '@/layouts/Layout.astro';
import { joinApiUrl } from '@/utils/url';

const newsletterConfirmUrl = joinApiUrl(getPublicSiteConfig().apiUrl, '/newsletter/confirm');
---

<Layout title="Confirm Newsletter Subscription — RELab">
  <TokenAction
    title="Newsletter Subscription"
    apiUrl={newsletterConfirmUrl}
    loadingMessage="Confirming your newsletter subscription…"
    successMessage="Newsletter subscription confirmed! Redirecting to the homepage…"
    noTokenMessage="No confirmation token provided. Please check your confirmation email."
    defaultErrorMessage="Confirmation failed. Please try registering again."
  />
</Layout>
