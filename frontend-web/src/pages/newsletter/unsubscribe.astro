---
import TokenAction from '@/components/TokenAction.astro';
import { getPublicSiteConfig } from '@/config/public';
import { newsletterContent } from '@/content';
import Layout from '@/layouts/Layout.astro';
import { joinApiUrl } from '@/utils/url';

const newsletterUnsubscribeUrl = joinApiUrl(
  getPublicSiteConfig().apiUrl,
  '/newsletter/unsubscribe',
);
---

<Layout title={newsletterContent.unsubscribeToken.documentTitle}>
  <TokenAction
    title={newsletterContent.unsubscribeToken.title}
    apiUrl={newsletterUnsubscribeUrl}
    loadingMessage={newsletterContent.unsubscribeToken.loadingMessage}
    successMessage={newsletterContent.unsubscribeToken.successMessage}
    noTokenMessage={newsletterContent.unsubscribeToken.noTokenMessage}
    defaultErrorMessage={newsletterContent.unsubscribeToken.defaultErrorMessage}
  />
</Layout>
