---
import TokenAction from '@/components/TokenAction.astro';
import { getPublicSiteConfig } from '@/config/public';
import Layout from '@/layouts/Layout.astro';
import { joinApiUrl } from '@/utils/url';

const newsletterUnsubscribeUrl = joinApiUrl(
  getPublicSiteConfig().apiUrl,
  '/newsletter/unsubscribe',
);
---

<Layout title="Unsubscribe from Newsletter — RELab">
  <TokenAction
    title="Unsubscribe from Newsletter"
    apiUrl={newsletterUnsubscribeUrl}
    loadingMessage="Unsubscribing from the newsletter…"
    successMessage="Successfully unsubscribed. Redirecting to the homepage…"
    noTokenMessage="No token provided. Please check your email."
    defaultErrorMessage="Unsubscription failed. Please try again."
  />
</Layout>
