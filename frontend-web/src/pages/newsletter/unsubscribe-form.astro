---
import EmailForm from '@/components/EmailForm.astro';
import { getPublicSiteConfig } from '@/config/public';
import Layout from '@/layouts/Layout.astro';
import { joinApiUrl } from '@/utils/url';

const newsletterRequestUnsubscribeUrl = joinApiUrl(
  getPublicSiteConfig().apiUrl,
  '/newsletter/request-unsubscribe',
);
---

<Layout title="Unsubscribe from Newsletter — RELab">
  <div class="content-page content-page-compact stack-md">
    <section class="page-intro content-reveal">
      <h1>Unsubscribe from Newsletter</h1>
      <p>Enter your email address and we’ll send a confirmation link to complete the unsubscribe request.</p>
    </section>

    <div class="card narrow-card content-reveal">
      <EmailForm
        apiUrl={newsletterRequestUnsubscribeUrl}
        placeholder="Your email address"
        buttonText="Unsubscribe"
        buttonVariant="btn-primary"
      >
        <p class="muted-text">
          This confirmation step makes sure only the owner of the address can unsubscribe it.
        </p>
      </EmailForm>
    </div>
  </div>
</Layout>
