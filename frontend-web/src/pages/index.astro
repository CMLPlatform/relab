---
import EmailForm from '@/components/EmailForm.astro';
import Layout from '@/layouts/Layout.astro';
import { joinApiUrl } from '@/utils/url';

const apiUrl = import.meta.env.PUBLIC_API_URL;
const appUrl = import.meta.env.PUBLIC_APP_URL;
const docsUrl = import.meta.env.PUBLIC_DOCS_URL;
const githubUrl = 'https://github.com/CMLPlatform/relab';
const newsletterSubscribeUrl = joinApiUrl(apiUrl, '/newsletter/subscribe');
---

<Layout title="Reverse Engineering Lab">
  <section class="hero card" data-animate>
    <h1>Reverse Engineering Lab</h1>
    <p class="lead">
      Welcome to RELab, a research platform for bottom-up product data collection, teardown documentation, and
      circularity analysis. Open the app to work with product data, or use the links below for documentation and source.
    </p>

    <div class="cta-row">
      <a href={appUrl} class="btn btn-primary btn-large" target="_blank" rel="noopener noreferrer">Open the App</a>
    </div>

    <div class="hero-footer">
      <p class="hero-note">Need more context?</p>
      <div class="hero-links">
        <a href={docsUrl} class="text-link" target="_blank" rel="noopener noreferrer">Read the Docs</a>
        <a href={githubUrl} class="text-link" target="_blank" rel="noopener noreferrer">Browse GitHub</a>
      </div>
    </div>
  </section>

  <section class="card newsletter-card" data-animate>
    <div class="newsletter-copy">
      <h2>Get project updates by email</h2>
      <p>If you want occasional project or research updates, leave your email here. You can unsubscribe at any time.</p>
    </div>

    <div class="newsletter-form">
      <EmailForm
        apiUrl={newsletterSubscribeUrl}
        buttonText="Subscribe"
        submittingText="Subscribing…"
        successMessage="Thanks for subscribing! Please check your email for confirmation."
      >
        <p class="muted-text">
          By subscribing, you agree to our <a href="/privacy">Privacy Policy</a>.
        </p>
      </EmailForm>
    </div>
  </section>
</Layout>

<script>
  document.querySelectorAll<Element>('[data-animate]').forEach((block, index) => {
    setTimeout(() => block.classList.add('is-visible'), 80 * index);
  });
</script>

<style>
  h1 {
    font-size: clamp(2.05rem, 4.4vw, 3.25rem);
    font-weight: 700;
    margin: 0 0 0.9rem;
    max-width: 18ch;
    line-height: 1.08;
  }

  h2 {
    font-size: clamp(1.25rem, 2.8vw, 1.75rem);
    font-weight: 600;
  }

  [data-animate] {
    opacity: 0;
    transform: translateY(14px);
    transition:
      opacity 420ms ease,
      transform 420ms ease;
  }

  [data-animate].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .hero {
    position: relative;
    overflow: hidden;
    padding: 2rem 2rem 1.8rem;
    background:
      radial-gradient(circle at 7% 6%, rgba(0, 103, 131, 0.12), transparent 36%),
      radial-gradient(circle at 92% 10%, rgba(92, 91, 125, 0.08), transparent 40%), var(--color-surface);
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: auto -12% -58% auto;
    width: min(360px, 58vw);
    aspect-ratio: 1 / 1;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(0, 103, 131, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .lead {
    color: var(--color-muted);
    font-size: clamp(1.02rem, 1.8vw, 1.12rem);
    line-height: 1.78;
    max-width: 100%;
  }

  .cta-row {
    margin-top: 1.1rem;
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .hero-footer {
    margin-top: 1.15rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding-top: 1rem;
    border-top: 1px solid color-mix(in srgb, var(--color-border) 78%, transparent);
  }

  .hero-note {
    margin: 0;
    font-size: 0.86rem;
    color: var(--color-muted);
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem 1rem;
  }

  .text-link {
    color: var(--color-primary-strong);
    text-decoration: none;
    font-weight: 600;
  }

  .text-link:hover {
    text-decoration: underline;
  }

  .newsletter-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.85fr);
    gap: 1rem 1.25rem;
    align-items: start;
    padding: 0.95rem 1.1rem;
    background: color-mix(in srgb, var(--color-surface) 96%, var(--color-primary-light));
    box-shadow: none;
  }

  .newsletter-card h2 {
    margin-top: 0.1rem;
    font-size: clamp(1.08rem, 2vw, 1.35rem);
  }

  .newsletter-card p {
    color: var(--color-muted);
    max-width: 66ch;
    line-height: 1.6;
  }

  @media (max-width: 760px) {
    .hero {
      padding: 1.35rem;
    }

    .newsletter-card {
      grid-template-columns: 1fr;
    }

    .input-row {
      flex-direction: column;
    }
  }
</style>
