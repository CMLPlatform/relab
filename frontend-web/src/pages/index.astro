---

import Hero from '@/components/Hero.astro';
import { getPublicSiteConfig } from '@/config/public.ts';
import { siteLinks, siteMeta } from '@/content/site-meta.ts';
import Layout from '@/layouts/Layout.astro';

const publicSiteConfig = getPublicSiteConfig();
---

<Layout
  title="RELab | Reverse engineering platform for product data and disassembly records"
  description={siteMeta.defaultDescription}
>
  <Hero
    appUrl={publicSiteConfig.appUrl}
    docsUrl={publicSiteConfig.docsUrl}
    githubUrl={siteLinks.github}
  />
</Layout>
