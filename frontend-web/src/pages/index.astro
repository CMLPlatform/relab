---
import Hero from '@/components/Hero.astro';
import NewsletterSignup from '@/components/NewsletterSignup.astro';
import { getPublicSiteConfig } from '@/config/public';
import { homeContent, siteLinks } from '@/content';
import Layout from '@/layouts/Layout.astro';
import { joinApiUrl } from '@/utils/url';

const publicSiteConfig = getPublicSiteConfig();
const newsletterSubscribeUrl = joinApiUrl(publicSiteConfig.apiUrl, '/newsletter/subscribe');
---

<Layout title="Reverse Engineering Lab" description={homeContent.heroBody}>
  <Hero
    appUrl={publicSiteConfig.appUrl}
    docsUrl={publicSiteConfig.docsUrl}
    githubUrl={siteLinks.github}
  />

  <NewsletterSignup apiUrl={newsletterSubscribeUrl} />
</Layout>
