# Development environment variables for the web frontend.

### Public variables
## URLs for related services (overridden by compose.dev.yml in Docker)
PUBLIC_API_URL='http://localhost:8011'    # The URL of the locally hosted backend API.
PUBLIC_DOCS_URL='http://localhost:8012' # The URL of the locally hosted Zensical documentation.
PUBLIC_APP_URL='http://localhost:8013'    # The URL of the locally hosted frontend application.
PUBLIC_SITE_URL='http://localhost:8081'   # The URL of the locally hosted website.

# Other public variables
PUBLIC_LINKEDIN_URL='https://www.linkedin.com/groups/15671021' # The URL of the LinkedIn page.
PUBLIC_CONTACT_EMAIL='relab@cml.leidenuniv.nl' # The email address for contact inquiries.

### Internal variables
ASTRO_TELEMETRY_DISABLED=1
