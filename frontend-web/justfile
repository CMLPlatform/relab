# Frontend Web Task Runner
# Run `just --list` to see all available commands
# Run from root: `just frontend-web/<recipe>` or from frontend-web/: `just <recipe>`

# Show available recipes
default:
    @just --list

# Install dependencies
install:
    npm ci

# ============================================================================
# Development
# ============================================================================

# Start development server
dev:
    npm run dev

# ============================================================================
# Building
# ============================================================================

# Build for production
build:
    npm run build:prod

# Build for staging (loads .env.staging via --mode staging)
build-staging:
    npm run build:staging

# ============================================================================
# Quality Checks
# ============================================================================

# Run Astro's project validation
typecheck:
    npx astro check

# Lint with Biome (read-only)
lint:
    npm run lint

# Auto-format code with Biome
format:
    npm run format

# Auto-fix what the formatter can fix
fix: format
    @echo "✓ Frontend-web code formatted"

# Run all frontend-web checks
check: lint typecheck
    @echo "✓ Frontend-web checks passed"

# ============================================================================
# Testing
# ============================================================================

# Run unit tests
test:
    npm run test

# Run tests with coverage report (for CI)
test-cov:
    npm run test:coverage

# Run the frontend-web CI test suite
test-ci: test-cov
    @echo "✓ Frontend-web CI test suite passed"

# Run end-to-end tests (requires a prior `just build`)
test-e2e:
    npm run test:e2e

# Open Playwright UI for interactive e2e test development
test-e2e-ui:
    npm run test:e2e:ui

# Run all tests (unit + e2e)
test-all:
    npm run test:all

# Run the full frontend-web CI pipeline locally
ci: check test-ci
    @echo "✓ Frontend-web CI pipeline passed"

# ============================================================================
# Security
# ============================================================================

# Scan dependencies for known vulnerabilities
audit:
    npm audit --audit-level=high --omit=dev
    @echo "✓ Dependency audit complete"

# Clean caches and build artifacts
clean:
    rm -rf .astro coverage dist playwright-report test-results
    @echo "✓ Cleaned caches and build artifacts"
