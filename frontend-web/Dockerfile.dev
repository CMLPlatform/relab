# Development Dockerfile for Web Frontend
# Note: This requires mounting the source code as a volume in docker-compose.override.yml
FROM node:24-slim@sha256:b8d2197aff9129d16c801a3e3e1b2a873c4946480f5a310f38056df2268c38d9

WORKDIR /opt/relab/frontend-web

# Copy package files and install dependencies
COPY package*.json ./
RUN npm ci

EXPOSE 8081

# Start the Expo dev server
CMD ["npx", "expo", "start", "--port", "8081", "--web"]
