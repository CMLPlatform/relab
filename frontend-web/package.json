  "contributors": [
    "Simon van Lierde <s.n.van.lierde@cml.leidenuniv.nl>"
  ],
  "scripts": {
    "dev": "astro dev --port 8081 --host",
    "build": "astro build",
    "build:production": "astro build --mode production",
    "build:staging": "astro build --mode staging",
    "preview": "astro preview --port 8081 --host",
    "check": "biome check . && astro check",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "astro": "^5.5.0",
    "tailwindcss": "^4.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@biomejs/biome": "^2.4.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "6.4.1",
    "vitest": "^3.2.4"
  }
}
