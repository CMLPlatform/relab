{
  "name": "relab-frontend-web",
  "type": "module",
  "version": "0.2.0",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": "24.x",
    "pnpm": "10.x"
  },
  "license": "AGPL-3.0-or-later",
  "contributors": [
    "Simon van Lierde <s.n.van.lierde@cml.leidenuniv.nl>"
  ],
  "scripts": {
    "dev": "astro dev --port 8081 --host 0.0.0.0 --strictPort --mode dev",
    "build": "astro build --mode prod",
    "build:prod": "astro build --mode prod",
    "build:staging": "astro build --mode staging",
    "build:test": "astro build --mode test",
    "preview": "astro preview --port 8081 --host 0.0.0.0 --strictPort",
    "preview:e2e": "pnpm run build && astro preview --port 8081 --host 0.0.0.0 --strictPort",
    "check": "pnpm run lint && pnpm run typecheck",
    "format": "biome format --write .",
    "fix": "biome check --write .",
    "lint": "biome check .",
    "typecheck": "astro check",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "audit": "pnpm audit --prod --audit-level high",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "ci": "pnpm run check && pnpm run test:ci"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.1.9"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@axe-core/playwright": "^4.11.2",
    "@biomejs/biome": "^2.4.13",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "happy-dom": "^20.9.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
