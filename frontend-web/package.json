{
  "name": "relab-frontend-web",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "24.x",
    "pnpm": "10.x"
  },
  "license": "AGPL-3.0-or-later",
  "contributors": [
    "Simon van Lierde <s.n.van.lierde@cml.leidenuniv.nl>"
  ],
  "scripts": {
    "dev": "astro dev --port 8081 --host --mode dev",
    "build": "astro build --mode prod",
    "build:prod": "astro build --mode prod",
    "build:staging": "astro build --mode staging",
    "build:test": "astro build --mode test",
    "preview": "astro preview --port 8081 --host",
    "check": "pnpm run lint && pnpm run typecheck",
    "format": "biome check --write .",
    "lint": "biome lint .",
    "typecheck": "astro check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "audit": "pnpm audit --prod --audit-level high",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "vitest run && playwright test"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.1.8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@axe-core/playwright": "^4.11.2",
    "@biomejs/biome": "^2.4.12",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "happy-dom": "^19.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
