{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["./biome.base.jsonc"],
  "files": {
    "includes": [
      // This root config covers the monorepo root itself.
      // Each subrepo owns its own Biome surface through its local biome.jsonc.
      // Semgrep fixture files intentionally contain invalid examples.
      "**",
      "!.semgrep",
      "!backend",
      "!app",
      "!www",
      "!docs"
    ]
  }
}
