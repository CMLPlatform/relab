# Development Dockerfile for Web Frontend
# Note: This requires mounting the source code as a volume in docker-compose.override.yml
FROM node:24-slim@sha256:0afb7822fac7bf9d7c1bf3b6e6c496dee6b2b64d8dfa365501a3c68e8eba94b2

WORKDIR /opt/relab/frontend-app

# Copy package files and install dependencies
COPY package*.json ./
RUN npm ci

EXPOSE 8081

# Start the Expo dev server
CMD ["npx", "expo", "start", "--port", "8081", "--web"]
