# Development Dockerfile for App Frontend (Expo)
# Note: Source is kept in image; use `docker compose watch` for hot reload
FROM node:24-slim@sha256:d8e448a56fc63242f70026718378bd4b00f8c82e78d20eefb199224a4d8e33d8

WORKDIR /opt/relab/frontend-app

ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH

# Install dependencies first (cached layer)
COPY package.json pnpm-lock.yaml ./
RUN corepack enable
RUN --mount=type=cache,target=/pnpm/store \
    pnpm install --frozen-lockfile

# Copy source files
COPY . .

EXPOSE 8081

# Start the Expo dev server. Keep Metro's cache across restarts; use the
# explicit dev-clean task when we actually need a cold cache.
CMD ["pnpm", "exec", "expo", "start", "--port", "8081", "--web"]
