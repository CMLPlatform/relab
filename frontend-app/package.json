{
  "name": "relab-frontend-app",
  "main": "expo-router/entry",
  "version": "0.2.0",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": "24.x",
    "pnpm": "11.x"
  },
  "scripts": {
    "dev": "expo start --web --port 8081",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "check": "pnpm run lint && pnpm run typecheck",
    "lint": "biome check . && pnpm run lint:react",
    "lint:react": "eslint --cache --max-warnings=0 src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "fix": "biome check --write . && eslint --cache --fix src --ext .ts,.tsx",
    "test": "jest --config jest.config.cjs",
    "test:unit": "jest --config config/jest/unit.cjs",
    "test:integration": "jest --config config/jest/integration.cjs",
    "test:watch": "jest --config jest.config.cjs --watchAll",
    "test:ci": "jest --config jest.config.cjs --ci --coverage",
    "build": "pnpm run build:web",
    "build:web": "expo export -p web -c",
    "profile:compiler:web": "BUILD_MODE=production expo start --web --clear",
    "audit": "pnpm audit --prod --audit-level high",
    "test:e2e": "playwright test",
    "test:e2e:cross-browser": "playwright test --project=chromium --project=firefox --project=webkit --project=mobile-chrome --project=mobile-safari",
    "test:e2e:ui": "playwright test --ui",
    "ci": "pnpm run check && pnpm run test:ci",
    "codegen:api": "openapi-typescript ${EXPO_PUBLIC_API_URL:-http://localhost:8011}/openapi_full.json -o src/types/api.generated.ts",
    "codegen:api:redact": "pnpm run codegen:api && node scripts/redact_api.js",
    "codegen": "pnpm run codegen:api:redact"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.0",
    "@expo/vector-icons": "^15.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "3.0.2",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.14",
    "@react-navigation/native": "^7.1.33",
    "@tanstack/react-query": "^5.99.2",
    "expo": "~55.0.17",
    "expo-auth-session": "~56.0.0",
    "expo-blur": "~56.0.0",
    "expo-constants": "~56.0.0",
    "expo-font": "~56.0.0",
    "expo-haptics": "~56.0.0",
    "expo-image": "~56.0.0",
    "expo-image-manipulator": "~56.0.0",
    "expo-image-picker": "~56.0.0",
    "expo-linear-gradient": "~56.0.0",
    "expo-linking": "~56.0.0",
    "expo-router": "~56.2.0",
    "expo-secure-store": "~56.0.0",
    "expo-splash-screen": "~56.0.0",
    "expo-status-bar": "~56.0.0",
    "expo-symbols": "~56.0.0",
    "expo-system-ui": "~56.0.0",
    "expo-video": "^56.0.0",
    "expo-web-browser": "~56.0.0",
    "hls.js": "^1.6.16",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.73.1",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-paper": "^5.15.1",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.4",
    "use-debounce": "^10.1.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@biomejs/biome": "^2.4.12",
    "@jest/globals": "~30.4.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.14",
    "@typescript-eslint/parser": "^8.59.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "baseline-browser-mapping": "^2.10.21",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jest": "~30.4.0",
    "jest-expo": "~56.0.0",
    "msw": "^2.13.5",
    "openapi-typescript": "^7.13.0",
    "serve": "^14.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.0"
  },
  "private": true,
  "pnpm": {
    "overrides": {
      "@tootallnate/once": "^3.0.1",
      "uuid": "^14.0.0"
    },
    "onlyBuiltDependencies": [
      "msw"
    ]
  }
}
