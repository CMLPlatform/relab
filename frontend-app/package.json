{
  "name": "relab-frontend-app",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "pnpm run typecheck && biome check .",
    "typecheck": "tsc --noEmit",
    "format": "biome check --write .",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage",
    "build:web": "expo export -p web -c",
    "build:test": "expo export -p web -c",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "codegen:api": "openapi-typescript ${EXPO_PUBLIC_API_URL:-http://localhost:8011}/openapi_full.json -o src/types/api.generated.ts",
    "codegen:api:redact": "pnpm run codegen:api && node scripts/redact_api.js"
  },
  "dependencies": {
    "@biomejs/biome": "^2.4.9",
    "@expo/vector-icons": "^15.0.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.33",
    "@tanstack/react-query": "^5.94.5",
    "expo": "~55.0.15",
    "expo-auth-session": "~55.0.14",
    "expo-blur": "~55.0.14",
    "expo-constants": "~55.0.14",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.8",
    "expo-image-manipulator": "~55.0.15",
    "expo-image-picker": "~55.0.18",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.13",
    "expo-router": "~55.0.12",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.18",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.15",
    "expo-video": "^55.0.15",
    "expo-web-browser": "~55.0.14",
    "hls.js": "^1.6.16",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.72.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-paper": "^5.14.5",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2",
    "use-debounce": "^10.1.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.10",
    "babel-plugin-react-compiler": "^1.0.0",
    "baseline-browser-mapping": "^2.10.9",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.16",
    "msw": "^2.12.13",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.6.2",
    "serve": "^14.2.6",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
