# Development overrides for the Expo app environment variables.
# URLs of related services (overridden by compose.override.yml in Docker)
EXPO_PUBLIC_API_URL='http://localhost:8011'    # The URL of the locally hosted backend API.
EXPO_PUBLIC_DOCS_URL='http://localhost:8012' # The URL of the locally hosted Zensical documentation.
EXPO_PUBLIC_WEBSITE_URL='http://localhost:8010'    # The URL of the locally hosted frontend website.
