# Development overrides for the Expo app environment variables.
# URLs of related services (overridden by compose.override.yml in Docker)
EXPO_PUBLIC_API_URL='http://localhost:8011'     # The URL of the locally hosted backend API.
EXPO_PUBLIC_WEBSITE_URL='http://localhost:8010' # The URL of the locally hosted frontend website.

# Copy below to an 'env.local' file or simply uncomment here to point the Expo app at your LAN IP so Expo Go on a phone can reach the backend.
# EXPO_PUBLIC_API_URL=http://192.168.X.X:8011
# EXPO_PUBLIC_WEBSITE_URL=http://192.168.X.X:8010

# Google OAuth web client ID — required for PKCE login on web (from Google Cloud Console > Credentials > Web application)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=''
