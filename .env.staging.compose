# .env.staging.compose — committed, non-secret Compose interpolation vars for staging.
# Loaded via `docker compose --env-file .env --env-file .env.staging.compose ...`
# (see justfile `staging_compose`). Secrets (TUNNEL_TOKEN, etc.) live in the
# gitignored root `.env` on each deploy host.

APP_ENV=staging
COMPOSE_PROJECT_NAME=relab_staging
WEB_CONCURRENCY=2
BUILD_MODE=staging
PUBLIC_SITE_URL=https://docs-test.cml-relab.org
CSP_API_ORIGIN=https://api-test.cml-relab.org
