# Frontend Web Task Runner
# Run `just --list` to see all available commands.
# For day-to-day work, `pnpm run <script>` works too — see package.json.
# This file holds composite recipes and anything called from the root justfile.

# Show available recipes
default:
    @just --list

# Install dependencies
install:
    pnpm install --frozen-lockfile

# Regenerate the lockfile without installing dependencies (called by pre-commit hook on package.json changes)
lockfile:
    pnpm install --lockfile-only --ignore-scripts

# Upgrade Astro and official integrations, then apply in-range pnpm updates.
# Uses `pnpm up` without --latest so majors stay intentional (opt in via Renovate PRs).
update:
    pnpm dlx @astrojs/upgrade
    pnpm up
    pnpm dedupe

# Run lint checks
lint:
    pnpm run lint

# Run static type checks
typecheck:
    pnpm run typecheck

# Start the standalone dev server using the root full-stack dev origins
dev:
    #!/usr/bin/env bash
    set -euo pipefail
    source ../deploy/env/dev.compose.env
    export PUBLIC_APP_URL="$APP_PUBLIC_URL"
    export PUBLIC_DOCS_URL="$DOCS_PUBLIC_URL"
    export PUBLIC_SITE_URL="$SITE_PUBLIC_URL"
    pnpm run dev

# Auto-format code with Biome
format:
    pnpm run format

# Auto-fix lint issues and format code
fix:
    pnpm run fix

# Run lint + typecheck
check: lint typecheck
    @echo "✅ Frontend-web checks passed"

# Build the production site
build:
    #!/usr/bin/env bash
    set -euo pipefail
    source ../deploy/env/prod.compose.env
    export PUBLIC_APP_URL="$APP_PUBLIC_URL"
    export PUBLIC_DOCS_URL="$DOCS_PUBLIC_URL"
    export PUBLIC_SITE_URL="$SITE_PUBLIC_URL"
    pnpm run build

# Run unit tests
test:
    pnpm run test

# Run the www CI test suite
test-ci:
    pnpm run test:ci

# Run browser end-to-end tests (always builds before preview)
test-e2e:
    pnpm run test:e2e

# Run the full www CI pipeline locally
ci: check test-ci
    @echo "✅ Frontend-web CI pipeline passed"

# Scan dependencies for known vulnerabilities
audit:
    pnpm run audit

# Clean caches and build artifacts
clean:
    rm -rf .astro coverage dist playwright-report test-results
