---

import ThemeControl from './ThemeControl.astro';

interface Props {
  contactEmail: string;
  currentYear: number;
  githubUrl: string;
  linkedInUrl?: string;
  youtubeUrl: string;
}

const { contactEmail, currentYear, githubUrl, linkedInUrl, youtubeUrl } = Astro.props;
const linkedInLabel = 'LinkedIn';
---

<footer class="site-footer">
  <div class="frame site-footer-inner">
    <div class="footer-meta">
      <a href="/" aria-label="Go to the homepage">Home</a>
      <a href="/privacy" aria-label="Read the RELab privacy policy">Privacy policy</a>
      <p class="footer-copy">© {currentYear} CML, Leiden University</p>
    </div>

    <nav class="footer-links" aria-label="Footer">
      <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
      <div class="footer-social">
        <a
          href={githubUrl}
          class="footer-icon-link"
          aria-label="GitHub"
          title="GitHub"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M12 2C6.475 2 2 6.475 2 12a10 10 0 0 0 6.838 9.488c.5.087.687-.213.687-.476 0-.237-.013-.875-.013-1.725-2.512.463-3.162-.612-3.362-1.175-.113-.288-.6-1.175-1.025-1.413-.35-.187-.85-.65-.013-.662.788-.013 1.35.725 1.538 1.025.9 1.512 2.338 1.087 2.912.825.088-.65.35-1.087.638-1.337-2.225-.25-4.55-1.113-4.55-4.938 0-1.088.387-1.987 1.025-2.688-.1-.25-.45-1.275.1-2.65 0 0 .837-.262 2.75 1.026a9.28 9.28 0 0 1 2.5-.338c.85 0 1.7.112 2.5.337 1.912-1.3 2.75-1.024 2.75-1.024.55 1.375.2 2.4.1 2.65.637.7 1.025 1.587 1.025 2.687 0 3.838-2.337 4.688-4.562 4.938.362.312.675.912.675 1.85 0 1.337-.013 2.412-.013 2.75 0 .262.188.574.688.474A10.016 10.016 0 0 0 22 12c0-5.525-4.475-10-10-10z"
            ></path>
          </svg>
        </a>
        {
          linkedInUrl && (
            <a
              href={linkedInUrl}
              class="footer-icon-link"
              aria-label="LinkedIn"
              title="LinkedIn"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
              <span class="sr-only">{linkedInLabel}</span>
            </a>
          )
        }
        <a
          href={youtubeUrl}
          class="footer-icon-link"
          aria-label="YouTube"
          title="YouTube"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2 31.2 31.2 0 0 0 0 12a31.2 31.2 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1A31.2 31.2 0 0 0 24 12a31.2 31.2 0 0 0-.5-5.8ZM9.6 15.6V8.4L15.9 12l-6.3 3.6Z" />
          </svg>
        </a>
      </div>
    </nav>

    <div class="footer-theme">
      <ThemeControl />
    </div>
  </div>
</footer>
