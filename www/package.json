{
  "name": "relab-www",
  "type": "module",
  "version": "0.2.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "contributors": [
    "Simon van Lierde <s.n.van.lierde@cml.leidenuniv.nl>"
  ],
  "scripts": {
    "dev": "astro dev --port 8081 --host 0.0.0.0 --strictPort --mode dev",
    "build": "astro build --mode prod",
    "build:prod": "astro build --mode prod",
    "build:staging": "astro build --mode staging",
    "build:test": "astro build --mode test",
    "preview": "astro preview --port 8081 --host 0.0.0.0 --strictPort",
    "preview:e2e": "just build && astro preview --port 8081 --host 0.0.0.0 --strictPort",
    "check": "pnpm run lint && pnpm run typecheck",
    "format": "biome format --write .",
    "fix": "biome check --write .",
    "lint": "biome check .",
    "typecheck": "astro check",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "audit": "pnpm audit --prod --audit-level moderate",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "ci": "pnpm run check && pnpm run test:ci"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "astro": "6.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "catalog:",
    "@axe-core/playwright": "catalog:",
    "@biomejs/biome": "catalog:",
    "@playwright/test": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "^4.1.5",
    "happy-dom": "^20.9.0",
    "typescript": "catalog:",
    "vitest": "^4.1.5"
  }
}
