---
const title = 'Page Not Found';
const description = 'The documentation page you requested could not be found.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Reverse Engineering Lab Docs</title>
    <meta name="description" content={description} />
    <style>
      :root {
        color-scheme: light;
        --page-bg: linear-gradient(180deg, #f4f1e8 0%, #e8efe6 48%, #dbe5f2 100%);
        --panel-bg: rgba(255, 255, 255, 0.88);
        --panel-border: rgba(37, 55, 72, 0.12);
        --text-main: #173042;
        --text-muted: #4d6474;
        --accent: #165d58;
        --accent-strong: #0f4743;
        --shadow: 0 24px 60px rgba(23, 48, 66, 0.14);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 2rem;
        background: var(--page-bg);
        color: var(--text-main);
        font-family: "IBM Plex Sans", system-ui, sans-serif;
      }

      main {
        width: min(100%, 48rem);
      }

      .panel {
        border: 1px solid var(--panel-border);
        border-radius: 1.5rem;
        padding: 2.5rem;
        background: var(--panel-bg);
        box-shadow: var(--shadow);
        backdrop-filter: blur(10px);
      }

      .eyebrow {
        margin: 0 0 0.75rem;
        color: var(--accent);
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0;
        font-family: "Space Grotesk", "IBM Plex Sans", system-ui, sans-serif;
        font-size: clamp(2.5rem, 6vw, 4.25rem);
        line-height: 0.95;
      }

      p {
        margin: 1rem 0 0;
        max-width: 42rem;
        color: var(--text-muted);
        font-size: 1.05rem;
        line-height: 1.7;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.875rem;
        margin-top: 2rem;
      }

      a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 2.9rem;
        padding: 0.75rem 1.1rem;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 700;
      }

      .primary {
        background: var(--accent);
        color: white;
      }

      .primary:hover,
      .primary:focus-visible {
        background: var(--accent-strong);
      }

      .secondary {
        border: 1px solid rgba(22, 93, 88, 0.18);
        color: var(--accent-strong);
        background: rgba(255, 255, 255, 0.72);
      }

      .secondary:hover,
      .secondary:focus-visible {
        background: rgba(22, 93, 88, 0.08);
      }

      @media (max-width: 640px) {
        body {
          padding: 1rem;
        }

        .panel {
          padding: 1.5rem;
        }

        .actions {
          flex-direction: column;
        }

        a {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <section class="panel">
        <p class="eyebrow">404</p>
        <h1>{title}</h1>
        <p>
          This docs URL does not exist anymore, or it may have moved while the platform docs were reorganized.
        </p>
        <div class="actions">
          <a class="primary" href="/">Go to Docs Home</a>
        </div>
      </section>
    </main>
  </body>
</html>
