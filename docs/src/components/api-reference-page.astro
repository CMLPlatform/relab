---
import { backendApiUrlForMode } from '../lib/backend-api.ts';

interface Props {
  schemaUrl: string;
  serverUrl?: string;
  title: string;
}

const { schemaUrl, serverUrl, title } = Astro.props;
const backendApiUrl = backendApiUrlForMode(import.meta.env.MODE);
const apiServerUrl = serverUrl ?? backendApiUrl;
const pageTitle = `${title} · RELab docs`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="api-reference-header">
      <a href="/">RELab docs</a>
      <h1>{title}</h1>
    </header>
    <main id="api-reference" data-backend-api-url={apiServerUrl} data-schema-url={schemaUrl}></main>
    <script src="../scripts/api-reference.ts"></script>
  </body>
</html>
