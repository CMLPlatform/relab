# Docs Task Runner
# Run `just --list` to see all available commands
# Run from root: `just docs/<recipe>` or from docs/: `just <recipe>`

# Show available recipes
default:
    @just --list

# Install dependencies
install:
    pnpm install --frozen-lockfile
    @echo "✓ Docs dependencies installed"

# Regenerate the lockfile without installing dependencies
lockfile:
    pnpm install --lockfile-only --ignore-scripts
    @echo "✓ Docs lockfile refreshed"

# Update dependencies (Astro upgrade + pnpm latest)
update:
    pnpm dlx @astrojs/upgrade
    pnpm up --latest
    @echo "✓ Docs dependencies updated"

# Start development server with live reload
dev PORT="8000":
    pnpm run dev -- --port {{ PORT }}

# Run lint checks
lint:
    pnpm run lint
    @echo "✓ Docs lint passed"

# Run static type checks
typecheck:
    pnpm run typecheck
    @echo "✓ Docs type checks passed"

# Build the static docs site
build:
    pnpm run build
    @echo "✓ Docs built"

# Print a simple static output budget for local review
size:
    du -sh dist
    find dist -type f | sort | xargs du -h

# Run fast quality checks (lint + typecheck)
check: lint typecheck
    @echo "✓ Docs checks passed"

# Auto-format docs code and markdown
format:
    pnpm run format
    @echo "✓ Docs formatted"

# Auto-fix lint issues and format code
fix:
    pnpm run fix
    @echo "✓ Docs code fixed and formatted"

# Docs has no unit tests; see `test-e2e` for Playwright suites
test:
    pnpm run test

# Browser end-to-end tests: smoke + a11y + visual + theme (requires `just build` first)
test-e2e:
    pnpm run test:e2e
    @echo "✓ Docs E2E tests passed"

# Run the docs CI test suite (build + e2e + link check)
test-ci:
    pnpm run test:ci
    @echo "✓ Docs CI test suite passed"

# Run the full docs CI pipeline locally
ci: check test-ci
    @echo "✓ Docs CI pipeline passed"

# Scan dependencies for known vulnerabilities
audit:
    pnpm run audit
    @echo "✓ Docs dependency audit complete"

# Clean caches and generated site output
clean:
    rm -rf .astro dist node_modules playwright-report test-results site
    @echo "✓ Cleaned docs caches and build artifacts"
