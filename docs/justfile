# Docs Task Runner
# Run `just --list` to see all available commands
# Run from root: `just docs/<recipe>` or from docs/: `just <recipe>`

# Show available recipes
default:
    @just --list

# Install dependencies
install:
    uv sync --all-groups
    @echo "✓ Docs dependencies installed"

# Update dependencies
update:
    uv lock --upgrade
    @echo "✓ Docs dependencies updated"

# Check code style and spelling
lint:
    uv run mdformat --check docs README.md
    npx cspell lint "docs/**/*.md" "README.md" --dot --config ../.cspell.yml
    @echo "✓ Docs linting passed"

# Format documentation
format:
    uv run mdformat docs README.md
    @echo "✓ Docs formatted"

# Automatically fix formatting issues
fix: format

# Run all quality checks (linting + build smoke test)
check: lint build
    @echo "✓ Docs checks passed"

# Start development server with live reload
dev PORT="8000":
    uv run zensical serve --open --dev-addr localhost:{{PORT}}

# Build the documentation site locally
build:
    uv run zensical build --clean
    @echo "✓ Docs built successfully"

# Smoke-test the build
test: build

# Run the full docs CI pipeline locally (lint + build, single pass)
ci: lint build
    @echo "✓ Docs CI pipeline passed"

# Scan Python dependencies for known CVEs
audit:
    uv audit --preview-features audit --frozen --no-dev
    @echo "✓ Docs: dependency audit complete"

# Clean caches and generated site output
clean:
    rm -rf .cache .ruff_cache __pycache__ site
    find . -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true
    find . -type f -name "*.pyc" -delete 2>/dev/null || true
    @echo "✓ Docs: Cleaned caches and build artifacts"
