# Docs Task Runner
# Run `just --list` to see all available commands
# Run from root: `just docs/<recipe>` or from docs/: `just <recipe>`

# Show available recipes
default:
    @just --list

# Install dependencies
install:
    pnpm install --frozen-lockfile
    @echo "✓ Docs dependencies installed"

# Regenerate the lockfile without installing dependencies
lockfile:
    pnpm install --lockfile-only --ignore-scripts
    @echo "✓ Docs lockfile refreshed"

# Update dependencies
update:
    npx @astrojs/upgrade
    @echo "✓ Docs dependencies updated"

# Check source quality
lint:
    pnpm run lint
    @echo "✓ Docs linting passed"

# Format documentation
format:
    pnpm run format
    @echo "✓ Docs formatted"

# Automatically fix formatting issues
fix: format

# Run all quality checks (linting + build smoke test)
check:
    pnpm run check
    @echo "✓ Docs checks passed"

# Start development server with live reload
dev PORT="8000":
    pnpm run dev -- --port {{PORT}}

# Build the documentation site locally
build:
    pnpm run build
    @echo "✓ Docs built successfully"

# Print a simple static output budget for local review
size:
    du -sh dist
    find dist -type f | sort | xargs du -h

# Smoke-test the build
test:
    pnpm run test
    @echo "✓ Docs tests passed"

# Run visual and theme regression checks
test-visual:
    pnpm run test:visual
    @echo "✓ Docs visual tests passed"

# Scan Node dependencies for known CVEs
audit:
    pnpm run audit
    @echo "✓ Docs dependency audit complete"

# Clean caches and generated site output
clean:
    rm -rf .astro dist node_modules playwright-report test-results site
    @echo "✓ Docs: Cleaned caches and build artifacts"
