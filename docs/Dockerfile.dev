# Development Dockerfile for Astro Starlight
FROM node:22-bookworm-slim@sha256:ef5d50c59a5eed0fa793b8390a88a298f30e438f56ce4488d9d8df7f93e7abdf

WORKDIR /opt/relab/docs

RUN corepack enable

COPY package.json pnpm-lock.yaml ./
RUN --mount=type=cache,target=/pnpm/store \
    pnpm install --frozen-lockfile

COPY . .

EXPOSE 8000

CMD ["pnpm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "8000"]
