          {
            "description": "MediaMTX-relative path, e.g. ``cam-preview/index.m3u8``",
            "in": "path",
            "name": "hls_path",
            "required": true,
            "schema": {
              "description": "MediaMTX-relative path, e.g. ``cam-preview/index.m3u8``",
              "pattern": "^[a-zA-Z0-9_\\-/\\.]+$",
              "title": "Hls Path",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Playlist (``application/vnd.apple.mpegurl``) or segment (``video/mp4``)."
