      "PairingRegisterRequest": {
        "description": "Pi -> backend pairing registration payload.",
        "properties": {
          "code": {
            "description": "6-character unambiguous uppercase pairing code generated by the Pi.",
            "maxLength": 6,
            "minLength": 6,
            "pattern": "^[ABCDEFGHJKLMNPQRSTUVWXYZ23456789]{6}$",
            "title": "Code",
            "type": "string"
          },
          "key_id": {
            "maxLength": 64,
