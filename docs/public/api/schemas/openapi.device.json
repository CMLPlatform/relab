      "DeviceImageUploadAck": {
        "description": "Backend -> Pi acknowledgement of a direct image upload.",
        "properties": {
          "image_id": {
            "description": "Stored backend image ID.",
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9._~-]+$",
            "title": "Image Id",
            "type": "string"
          },
          "image_url": {
            "description": "Backend-hosted URL for the stored image",
            "maxLength": 2048,
            "minLength": 1,
            "pattern": "^(https?://[^\\s]+|/([^\\s/][^\\s]*)?)$",
            "title": "Image Url",
            "type": "string"
          }
        },
        "required": [
          "image_id",
          "image_url"
        ],
        "title": "DeviceImageUploadAck",
        "type": "object"
      },
      "DevicePreviewThumbnailAck": {
        "description": "Backend -> Pi acknowledgement of a cached preview-thumbnail upload.",
        "properties": {
