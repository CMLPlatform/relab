  "openapi": "3.1.0",
  "paths": {
    "/v1/plugins/rpi-cam/device/cameras/{camera_id}/image-upload": {
      "post": {
        "description": "Called by the Pi after a successful capture. Authenticated with a short-lived ES256 device assertion (same credential used by the WebSocket relay). The Pi provides the JPEG body plus two JSON blobs: `capture_metadata` (libcamera metadata) and `upload_metadata` (opaque dict forwarded by whichever caller triggered the capture \u2014 typically `{product_id, description}`). The backend stores the image via the normal image storage service and returns a tiny ack envelope the Pi consumes.",
        "operationId": "receive_camera_upload_v1_plugins_rpi_cam_device_cameras__camera_id__image_upload_post",
        "parameters": [
          {
            "in": "path",
            "name": "camera_id",
            "required": true,
            "schema": {
              "format": "uuid4",
              "title": "Camera Id",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_receive_camera_upload_v1_plugins_rpi_cam_device_cameras__camera_id__image_upload_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeviceImageUploadAck"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Internal: receive an image pushed directly from a paired Raspberry Pi",
        "tags": [
          "rpi-cam-device",
          "rpi-cam-device"
        ],
        "x-audience": [
          "device"
        ]
      }
    },
    "/v1/plugins/rpi-cam/device/cameras/{camera_id}/preview-thumbnail-upload": {
      "post": {
        "description": "Called by the Pi's background thumbnail worker. Authenticated with the same short-lived ES256 device assertion used by the WebSocket relay. Stores a deterministic per-camera JPEG cache file for camera-card previews without creating an Image database row.",
        "operationId": "receive_preview_thumbnail_upload_v1_plugins_rpi_cam_device_cameras__camera_id__preview_thumbnail_upload_post",
        "parameters": [
          {
            "in": "path",
            "name": "camera_id",
            "required": true,
            "schema": {
              "format": "uuid4",
              "title": "Camera Id",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_receive_preview_thumbnail_upload_v1_plugins_rpi_cam_device_cameras__camera_id__preview_thumbnail_upload_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DevicePreviewThumbnailAck"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Internal: receive a cached preview thumbnail pushed directly from a paired Raspberry Pi",
        "tags": [
          "rpi-cam-device",
          "rpi-cam-device"
        ],
        "x-audience": [
          "device"
        ]
      }
    },
    "/v1/plugins/rpi-cam/device/cameras/{camera_id}/self": {
      "delete": {
        "description": "Called by the Pi when the user triggers unpair from the local /setup page. Authenticates via the device's ES256 assertion. Deletes the camera from the database so the backend no longer shows it as offline.",
        "operationId": "self_unpair_camera_v1_plugins_rpi_cam_device_cameras__camera_id__self_delete",
        "parameters": [
          {
            "in": "path",
            "name": "camera_id",
            "required": true,
            "schema": {
              "format": "uuid4",
              "title": "Camera Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Pi-initiated self-unpair",
        "tags": [
          "rpi-cam-device"
        ],
        "x-audience": [
          "device"
        ]
      }
    },
    "/v1/plugins/rpi-cam/pairing/claim": {
      "post": {
        "description": "Claim a pairing code and create a WebSocket-relayed camera.",
        "operationId": "claim_pairing_code_v1_plugins_rpi_cam_pairing_claim_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PairingClaimRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CameraRead"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "security": [
          {
            "OAuth2PasswordBearer": []
          },
          {
            "APIKeyCookie": []
          }
        ],
        "summary": "Claim a pairing code and create a camera (called by user)",
        "tags": [
          "RPi Camera Pairing"
        ],
        "x-audience": [
          "public",
          "app"
        ]
      }
    },
    "/v1/plugins/rpi-cam/pairing/poll": {
      "get": {
        "description": "Poll for pairing completion. Returns non-secret relay metadata once claimed.",
        "operationId": "poll_pairing_status_v1_plugins_rpi_cam_pairing_poll_get",
        "parameters": [
          {
            "in": "query",
            "name": "code",
            "required": true,
            "schema": {
              "maxLength": 6,
              "minLength": 6,
              "pattern": "^[ABCDEFGHJKLMNPQRSTUVWXYZ23456789]{6}$",
              "title": "Code",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "fingerprint",
            "required": true,
            "schema": {
              "maxLength": 64,
              "minLength": 8,
              "title": "Fingerprint",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PairingPollResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Poll pairing status (called by RPi)",
        "tags": [
          "RPi Camera Pairing"
        ],
        "x-audience": [
          "public",
          "app"
        ]
      }
    },
    "/v1/plugins/rpi-cam/pairing/register": {
      "post": {
        "description": "Register a short-lived pairing code and the camera's public device key.",
        "operationId": "register_pairing_code_v1_plugins_rpi_cam_pairing_register_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PairingRegisterRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PairingRegisterResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Register a pairing code (called by RPi)",
        "tags": [
          "RPi Camera Pairing"
        ],
        "x-audience": [
          "public",
          "app"
        ]
      }
    }
  },
