            "maxLength": 100,
            "minLength": 2,
            "title": "Camera Name",
            "type": "string"
          },
          "code": {
            "description": "Pairing code displayed on the RPi's setup page.",
            "maxLength": 6,
            "minLength": 6,
            "pattern": "^[ABCDEFGHJKLMNPQRSTUVWXYZ23456789]{6}$",
            "title": "Code",
            "type": "string"
          },
          "description": {
            "anyOf": [
              {
                "maxLength": 500,
